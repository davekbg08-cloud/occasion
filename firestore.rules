rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasUserRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isSeller() {
      return hasUserRole('seller');
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function hasOnly(data, keys) {
      return data.keys().hasOnly(keys);
    }

    // Statuts que le client peut légitimement s'attribuer lui-même (avant
    // toute vérification humaine). 'verified' et 'rejected' ne sont jamais
    // posés par le client : ce sont des décisions admin (Cloud Function /
    // Admin SDK, qui contourne ces règles).
    function isClientSettableIdentityStatus(value) {
      return value in ['unverified', 'phone_verified', 'identity_submitted'];
    }

    function stringField(data, field, max) {
      return data[field] is string && data[field].size() <= max;
    }

    function optionalString(data, field, max) {
      return !(field in data) || stringField(data, field, max);
    }

    function optionalNumber(data, field) {
      return !(field in data) || data[field] is number;
    }

    function optionalBool(data, field) {
      return !(field in data) || data[field] is bool;
    }

    function isPublishedAnnonce(data) {
      return data.statut in ['active', 'actif', 'published', 'publie']
        || data.status in ['active', 'published']
        || data.active == true
        || data.isPublished == true;
    }

    function isPublishedStatus(data) {
      return data.status in ['active', 'published']
        || data.active == true
        || data.isPublished == true;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId == request.auth.uid
          || get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid
        );
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function validAnnonce(data) {
      return hasOnly(data, [
        'id', 'sellerId', 'userId', 'title', 'titre', 'description',
        'price', 'prix', 'currency', 'devise', 'category', 'categorie',
        'brand', 'marque', 'model', 'modele', 'year', 'annee',
        'condition', 'etat', 'location', 'localisation', 'vendeurId',
        'city', 'ville', 'district', 'quartier', 'phone', 'telephone',
        'imageUrls', 'images', 'favoritesCount', 'favoris', 'views', 'vues',
        'messagesCount', 'statut', 'status', 'active', 'isActive',
        'isPublished', 'createdAt', 'dateCreation', 'updatedAt',
        'dateModification'
      ])
      && (stringField(data, 'title', 160) || stringField(data, 'titre', 160))
      && stringField(data, 'description', 4000)
      && (
        (data.price is number && data.price >= 0)
        || (data.prix is number && data.prix >= 0)
      )
      && (stringField(data, 'currency', 10) || stringField(data, 'devise', 10))
      && (stringField(data, 'category', 120) || stringField(data, 'categorie', 120))
      && optionalString(data, 'brand', 120)
      && optionalString(data, 'marque', 120)
      && optionalString(data, 'model', 120)
      && optionalString(data, 'modele', 120)
      && optionalNumber(data, 'year')
      && optionalNumber(data, 'annee')
      && optionalString(data, 'condition', 80)
      && optionalString(data, 'etat', 80)
      && optionalString(data, 'location', 180)
      && optionalString(data, 'localisation', 180)
      && optionalString(data, 'city', 120)
      && optionalString(data, 'ville', 120)
      && optionalString(data, 'district', 120)
      && optionalString(data, 'quartier', 120)
      && (
        stringField(data, 'sellerId', 128)
        || stringField(data, 'vendeurId', 128)
        || stringField(data, 'userId', 128)
      )
      && optionalString(data, 'sellerId', 128)
      && optionalString(data, 'vendeurId', 128)
      && optionalString(data, 'userId', 128)
      && optionalString(data, 'phone', 40)
      && optionalString(data, 'telephone', 40)
      && (
        (data.imageUrls is list && data.imageUrls.size() <= 5)
        || (data.images is list && data.images.size() <= 5)
      )
      && optionalNumber(data, 'favoritesCount')
      && optionalNumber(data, 'favoris')
      && optionalNumber(data, 'views')
      && optionalNumber(data, 'vues')
      && optionalNumber(data, 'messagesCount')
      && optionalString(data, 'statut', 40)
      && optionalString(data, 'status', 40)
      && optionalBool(data, 'active')
      && optionalBool(data, 'isActive')
      && optionalBool(data, 'isPublished')
      && (!( 'createdAt' in data) || data.createdAt == null || data.createdAt is timestamp)
      && (!( 'dateCreation' in data) || data.dateCreation == null || data.dateCreation is timestamp)
      && (!( 'updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp)
      && (!( 'dateModification' in data) || data.dateModification == null || data.dateModification is timestamp);
    }

    function validFavori(data) {
      return hasOnly(data, ['id', 'utilisateurId', 'annonceId', 'dateAjout'])
        && stringField(data, 'utilisateurId', 128)
        && stringField(data, 'annonceId', 128)
        && data.dateAjout is timestamp;
    }

    function validMessage(data) {
      return hasOnly(data, [
        'id', 'conversationId', 'expediteurId', 'destinataireId',
        'contenu', 'lu', 'dateEnvoi'
      ])
      && stringField(data, 'conversationId', 128)
      && stringField(data, 'expediteurId', 128)
      && stringField(data, 'destinataireId', 128)
      && stringField(data, 'contenu', 4000)
      && data.lu is bool
      && data.dateEnvoi is timestamp;
    }

    function validConversation(data) {
      return hasOnly(data, ['id', 'participants', 'dernierMessage', 'dateDernierMessage'])
        && data.participants is list
        && data.participants.size() >= 2
        && stringField(data, 'dernierMessage', 1000)
        && data.dateDernierMessage is timestamp;
    }

    function validSignalement(data) {
      return hasOnly(data, ['id', 'annonceId', 'utilisateurId', 'motif', 'description', 'date', 'statut'])
        && stringField(data, 'annonceId', 128)
        && stringField(data, 'utilisateurId', 128)
        && stringField(data, 'motif', 160)
        && optionalString(data, 'description', 2000)
        && data.date is timestamp
        && stringField(data, 'statut', 40);
    }

    function validCategorie(data) {
      return hasOnly(data, ['id', 'nom', 'icone', 'ordre'])
        && stringField(data, 'nom', 120)
        && optionalString(data, 'icone', 120)
        && data.ordre is number && data.ordre >= 0;
    }

    function validNotification(data) {
      return hasOnly(data, ['id', 'utilisateurId', 'titre', 'message', 'lu', 'date'])
        && stringField(data, 'utilisateurId', 128)
        && stringField(data, 'titre', 160)
        && stringField(data, 'message', 1000)
        && data.lu is bool
        && data.date is timestamp;
    }

    match /annonces/{annonceId} {
      allow read: if isPublishedAnnonce(resource.data)
        || (
          signedIn()
          && (
            resource.data.sellerId == request.auth.uid
            || resource.data.vendeurId == request.auth.uid
            || resource.data.userId == request.auth.uid
          )
        );
      allow create: if signedIn()
        && isSeller()
        && (
          request.resource.data.sellerId == request.auth.uid
          || request.resource.data.vendeurId == request.auth.uid
          || request.resource.data.userId == request.auth.uid
        )
        && validAnnonce(request.resource.data);
      allow update: if signedIn()
        && validAnnonce(request.resource.data)
        && (
          (
            isSeller()
            && (
              resource.data.sellerId == request.auth.uid
              || resource.data.vendeurId == request.auth.uid
              || resource.data.userId == request.auth.uid
            )
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoris', 'vues', 'dateModification'])
        );
      allow delete: if signedIn()
        && isSeller()
        && (
          resource.data.sellerId == request.auth.uid
          || resource.data.vendeurId == request.auth.uid
          || resource.data.userId == request.auth.uid
        );
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      // Création du compte (inscription) : le client choisit son rôle et
      // son statut d'identité initial, mais ne peut jamais se créer déjà
      // "vérifié", ni s'attribuer un abonnement vendeur.
      allow create: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role in ['buyer', 'seller'])
        && (!('identityStatus' in request.resource.data) || isClientSettableIdentityStatus(request.resource.data.identityStatus))
        && (!('sellerStatus' in request.resource.data) || isClientSettableIdentityStatus(request.resource.data.sellerStatus))
        && !('sellerSubscriptionActive' in request.resource.data)
        && !('sellerSubscriptionExpiresAt' in request.resource.data);

      // Mise à jour : le rôle et l'abonnement vendeur ne sont plus jamais
      // modifiables par le client une fois le compte créé (uniquement par
      // une Cloud Function via l'Admin SDK, qui contourne ces règles).
      // Le statut d'identité ne peut être déplacé que vers un statut de
      // "soumission" (jamais 'verified'/'rejected', décision admin).
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ['role', 'sellerSubscriptionActive', 'sellerSubscriptionExpiresAt']
          )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['identityStatus', 'sellerStatus'])
          || (
            isClientSettableIdentityStatus(request.resource.data.identityStatus)
            && isClientSettableIdentityStatus(request.resource.data.sellerStatus)
          )
        );

      allow delete: if false;

      match /blockedUsers/{blockedUserId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /publicProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId)
        && hasOnly(request.resource.data, [
          'id', 'name', 'role', 'profileImageUrl', 'identityStatus',
          'sellerStatus', 'phoneVerified', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.id == userId
        && optionalString(request.resource.data, 'name', 160)
        && optionalString(request.resource.data, 'role', 40)
        && optionalString(request.resource.data, 'profileImageUrl', 2000)
        && optionalString(request.resource.data, 'identityStatus', 40)
        && optionalString(request.resource.data, 'sellerStatus', 40)
        && optionalBool(request.resource.data, 'phoneVerified');
      allow delete: if isOwner(userId);
    }

    match /utilisateurs/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /favoris/{favoriId} {
      allow read: if signedIn() && resource.data.utilisateurId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.utilisateurId == request.auth.uid
        && validFavori(request.resource.data);
      allow update: if false;
      allow delete: if signedIn() && resource.data.utilisateurId == request.auth.uid;
    }

    match /statuses/{statusId} {
      allow read: if isPublishedStatus(resource.data)
        || (signedIn() && resource.data.sellerId == request.auth.uid);
      allow create: if signedIn()
        && isSeller()
        && request.resource.data.sellerId == request.auth.uid
        && isPublishedStatus(request.resource.data);
      allow update: if signedIn()
        && (
          (resource.data.sellerId == request.auth.uid && isSeller())
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
        );
      allow delete: if signedIn()
        && isSeller()
        && resource.data.sellerId == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if resource.data.status in ['active', 'published']
        || resource.data.statut in ['active', 'published']
        || resource.data.isActive == true
        || (signedIn() && resource.data.sellerId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.sellerId == request.auth.uid
        && isSeller();
      allow update, delete: if signedIn()
        && isSeller()
        && resource.data.sellerId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if signedIn()
        && (resource.data.expediteurId == request.auth.uid || resource.data.destinataireId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.expediteurId == request.auth.uid
        && validMessage(request.resource.data);
      allow update: if signedIn()
        && validMessage(request.resource.data)
        && (resource.data.expediteurId == request.auth.uid || resource.data.destinataireId == request.auth.uid);
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && validConversation(request.resource.data);
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && validConversation(request.resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isConversationParticipant(conversationId)
          && request.resource.data.expediteurId == request.auth.uid
          && validMessage(request.resource.data);
        allow update: if isConversationParticipant(conversationId)
          && validMessage(request.resource.data)
          && (
            resource.data.expediteurId == request.auth.uid
            || resource.data.destinataireId == request.auth.uid
          );
        allow delete: if false;
      }
    }

    match /chats/{chatId} {
      allow create: if signedIn()
        && (
          request.resource.data.buyerId == request.auth.uid
          || request.resource.data.sellerId == request.auth.uid
        );
      // 'read' autorise aussi un document inexistant (le client fait un
      // get-then-create dans getOrCreateChat) : sans cette garde,
      // resource.data serait null et Firestore refuserait systématiquement
      // le tout premier message de chaque conversation.
      allow read: if signedIn()
        && (
          !exists(/databases/$(database)/documents/chats/$(chatId))
          || resource.data.buyerId == request.auth.uid
          || resource.data.sellerId == request.auth.uid
        );
      allow update, delete: if signedIn()
        && (
          resource.data.buyerId == request.auth.uid
          || resource.data.sellerId == request.auth.uid
        );

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.receiverId in [
            get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId,
            get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId
          ];
        allow update: if isChatParticipant(chatId)
          && resource.data.receiverId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        allow delete: if false;
      }
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn()
        && (
          subscriptionId == request.auth.uid
          || resource.data.userId == request.auth.uid
        );
      // Seules les Cloud Functions confirmManualPayment / rejectManualPayment
      // (Admin SDK, contournent ces règles) peuvent activer un abonnement,
      // après vérification manuelle du paiement par un admin.
      allow create, update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      // Les transactions ne sont créées/mises à jour que côté serveur
      // (Cloud Functions), après vérification réelle du paiement.
      allow create, update, delete: if false;
    }

    match /paymentIntents/{transactionId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      // Le client peut soumettre une référence de paiement manuel Orange
      // Money pour vérification humaine par un admin. Le passage final à
      // 'paid'/'failed' reste réservé au serveur.
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'manualPaymentMethod', 'manualPaymentReference', 'updatedAt'
        ])
        && request.resource.data.status == 'awaiting_manual_verification'
        && stringField(request.resource.data, 'manualPaymentReference', 120);
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.status == 'pending_payment';
      allow read: if signedIn()
        && (
          resource.data.buyerId == request.auth.uid
          || ('sellerIds' in resource.data && request.auth.uid in resource.data.sellerIds)
          || isAdmin()
        );
      // Le client peut annuler, marquer "en cours de paiement", ou
      // soumettre une référence de paiement manuel Orange Money pour
      // vérification humaine. Le passage à 'paid'/'payment_failed' est
      // réservé au serveur (Cloud Function), après confirmation manuelle
      // par un admin.
      allow update: if signedIn()
        && (
          (
            resource.data.buyerId == request.auth.uid
            && (
              (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'updatedAt'
                ])
                && request.resource.data.status in ['processing_payment', 'cancelled']
              )
              || (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'updatedAt', 'manualPaymentMethod', 'manualPaymentReference'
                ])
                && request.resource.data.status == 'awaiting_manual_verification'
                && stringField(request.resource.data, 'manualPaymentReference', 120)
              )
              // Séquestre : l'acheteur confirme avoir bien reçu l'article
              // (libère les fonds pour reversement) uniquement depuis 'paid'.
              || (
                resource.data.status == 'paid'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'updatedAt', 'completedAt'
                ])
                && request.resource.data.status == 'completed'
              )
              // Séquestre : l'acheteur signale un problème (bloque la
              // libération automatique, un admin doit trancher).
              || (
                resource.data.status == 'paid'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'updatedAt', 'disputeReason', 'disputedAt'
                ])
                && request.resource.data.status == 'disputed'
                && stringField(request.resource.data, 'disputeReason', 500)
              )
            )
          )
          // Reversement au vendeur : uniquement un admin, uniquement depuis
          // 'completed', jamais de retour en arrière possible.
          || (
            isAdmin()
            && resource.data.status == 'completed'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'updatedAt', 'payoutSentAt', 'payoutSentBy'
            ])
            && request.resource.data.status == 'payout_sent'
          )
          // Un admin peut résoudre un litige en le renvoyant vers
          // 'completed' (reversement) ou 'cancelled' (remboursement).
          || (
            isAdmin()
            && resource.data.status == 'disputed'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'updatedAt', 'resolutionNote'
            ])
            && request.resource.data.status in ['completed', 'cancelled']
          )
        );
      allow delete: if false;
    }

    match /signalements/{signalementId} {
      allow create: if signedIn()
        && request.resource.data.utilisateurId == request.auth.uid
        && validSignalement(request.resource.data);
      allow read, update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /categories/{categorieId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.token.admin == true
        && validCategorie(request.resource.data);
      allow delete: if signedIn() && request.auth.token.admin == true;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.utilisateurId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.utilisateurId == request.auth.uid
        && validNotification(request.resource.data);
      allow update: if signedIn()
        && resource.data.utilisateurId == request.auth.uid
        && validNotification(request.resource.data);
      allow delete: if signedIn() && resource.data.utilisateurId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
